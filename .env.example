# ─────────────────────────────────────────────────────────────
# Project AlphaQ — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Provider Selection ────────────────────────────────────────
# Options: openai | openrouter | ollama
LLM_PROVIDER=ollama

# ── Model Selection ───────────────────────────────────────────
# Ollama examples   : llama3, mistral, mixtral, deepseek-coder, llama3.1:8b-instruct-q4_K_M
# OpenRouter examples: openai/gpt-4o, anthropic/claude-3-opus, google/gemini-pro
LLM_MODEL=llama3.1:8b-instruct-q4_K_M

# ── OpenRouter ──────────────────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

# ── Binance Trading (optional) ─────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Ollama (local) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Server ────────────────────────────────────────────────────
PORT=8000
ENV=production